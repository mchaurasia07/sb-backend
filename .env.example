APP_NAME=SB Backend
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1

MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=storybook
DATABASE_URL=mysql+aiomysql://root:root@127.0.0.1:3306/storybook

JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

BCRYPT_ROUNDS=12
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8080
RATE_LIMIT_DEFAULT=100/minute

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Storybook
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=10

MEDIA_ROOT=photo
MEDIA_URL_PREFIX=/photo
IMAGE_MAX_UPLOAD_BYTES=5242880


OPENAI_API_KEY=sk-...
OPENAI_IMAGE_MODEL=dall-e-3
CHARACTER_IMAGE_SIZE=1024x1024
CHARACTER_IMAGE_QUALITY=standard
CHARACTER_GENERATION_ENABLED=true
