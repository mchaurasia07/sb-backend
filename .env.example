APP_NAME=SB Backend
ENVIRONMENT=local
APP_DEBUG=true
API_V1_PREFIX=/api/v1

DATABASE_URL=mysql+asyncmy://root:root@localhost:3306/storybook
DB_POOL_PRE_PING=true
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=300

JWT_SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=525600
REFRESH_TOKEN_EXPIRE_DAYS=30

BCRYPT_ROUNDS=12
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8081
RATE_LIMIT_DEFAULT=100/minute

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@example.com
SMTP_FROM_NAME=Storybook
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=10

# Storage paths - use absolute paths for production deployment.
# Relative MEDIA_ROOT and AUDIO_ROOT are resolved from the app working directory.
# Windows example: D:/storage/images
# Linux example: /var/storybook/images
MEDIA_ROOT=photo
MEDIA_URL_PREFIX=/photo
IMAGE_MAX_UPLOAD_BYTES=5242880
IMAGE_STORAGE_PROVIDER=r2

# Cloudflare R2 image storage.
CLOUDFLARE_R2_ACCOUNT_ID=f978b2a795e5502550901e673ab2d25a
CLOUDFLARE_R2_ACCESS_KEY_ID=445e9dfbb7daca19b8437ef6cec3ba14
CLOUDFLARE_R2_SECRET_ACCESS_KEY=a379469c42a09441a84bee26ffab5230983e9c122cfa514bc2c459e7ddd9ed50
CLOUDFLARE_R2_BUCKET_NAME=ts-storage-bucket-dev
# Public bucket/custom domain base URL, for example https://media.example.com
CLOUDFLARE_R2_PUBLIC_BASE_URL=https://f978b2a795e5502550901e673ab2d25a.r2.cloudflarestorage.com
CLOUDFLARE_R2_IMAGE_KEY_PREFIX=photo
CLOUDFLARE_R2_REGION=auto
CLOUDFLARE_R2_CACHE_CONTROL=public, max-age=31536000, immutable

# Audio Storage - use absolute paths for production deployment
# Windows example: D:/storage/audio
# Linux example: /var/storybook/audio
AUDIO_ROOT=audio
AUDIO_URL_PREFIX=/audio
AUDIO_STORAGE_PROVIDER=r2
CLOUDFLARE_R2_AUDIO_KEY_PREFIX=audio

AI_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1-mini
OPENAI_TEXT_MODEL=gpt-4-mini

GOOGLE_API_KEY=
GOOGLE_TEXT_MODEL=gemini-2.5-flash
GOOGLE_IMAGE_MODEL=imagen-4.0-generate-001
GOOGLE_REFERENCE_IMAGE_MODEL=gemini-2.5-flash-image
GOOGLE_TTS_MODEL=gemini-3.1-flash-tts-preview
GOOGLE_TTS_VOICE=Kore
GOOGLE_TTS_SKIP_CALL=false

CHARACTER_IMAGE_SIZE=1024x1024
CHARACTER_IMAGE_QUALITY=high
CHARACTER_GENERATION_ENABLED=true

STORY_MOCK_LLM_RESPONSES=True
STORY_TEXT_MODEL=gpt-4o
STORY_IMAGE_MODEL=dall-e-3
STORY_IMAGE_SIZE=1024x1024
STORY_COVER_IMAGE_SIZE=1024x1536
STORY_PAGE_IMAGE_SIZE=1024x1024
STORY_BACK_COVER_IMAGE_SIZE=1024x1536
STORY_COVER_ASPECT_RATIO=3:4
STORY_PAGE_ASPECT_RATIO=1:1
STORY_BACK_COVER_ASPECT_RATIO=3:4
STORY_IMAGE_QUALITY=standard
STORY_MAX_RETRIES=3
STORY_GENERATION_ENABLED=true
