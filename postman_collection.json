{
  "info": {
    "name": "SB Backend API",
    "description": "Postman collection for the kids storytelling mobile backend REST API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "api_prefix",
      "value": "/api/v1"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    },
    {
      "key": "child_id",
      "value": ""
    },
    {
      "key": "email",
      "value": "parent@example.com"
    },
    {
      "key": "phone",
      "value": "+15551234567"
    },
    {
      "key": "password",
      "value": "StrongPass@123"
    },
    {
      "key": "otp",
      "value": "123456"
    },
    {
      "key": "google_id_token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"phone\": \"{{phone}}\",\n  \"password\": \"{{password}}\",\n  \"confirm_password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/auth/signup",
              "host": [
                "{{base_url}}{{api_prefix}}"
              ],
              "path": [
                "auth",
                "signup"
              ]
            }
          }
        },
        {
          "name": "Verify Email OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"otp\": \"{{otp}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/auth/verify-email-otp",
              "host": [
                "{{base_url}}{{api_prefix}}"
              ],
              "path": [
                "auth",
                "verify-email-otp"
              ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data) {",
                  "  pm.collectionVariables.set('access_token', json.data.access_token);",
                  "  pm.collectionVariables.set('refresh_token', json.data.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/auth/login",
              "host": [
                "{{base_url}}{{api_prefix}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Google Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data) {",
                  "  pm.collectionVariables.set('access_token', json.data.access_token);",
                  "  pm.collectionVariables.set('refresh_token', json.data.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_token\": \"{{google_id_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/auth/google-login",
              "host": [
                "{{base_url}}{{api_prefix}}"
              ],
              "path": [
                "auth",
                "google-login"
              ]
            }
          }
        },
        {
          "name": "Add Phone",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phone}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/auth/add-phone",
              "host": [
                "{{base_url}}{{api_prefix}}"
              ],
              "path": [
                "auth",
                "add-phone"
              ]
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/auth/forgot-password",
              "host": [
                "{{base_url}}{{api_prefix}}"
              ],
              "path": [
                "auth",
                "forgot-password"
              ]
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"otp\": \"{{otp}}\",\n  \"new_password\": \"{{password}}\",\n  \"confirm_password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/auth/reset-password",
              "host": [
                "{{base_url}}{{api_prefix}}"
              ],
              "path": [
                "auth",
                "reset-password"
              ]
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data) {",
                  "  pm.collectionVariables.set('access_token', json.data.access_token);",
                  "  pm.collectionVariables.set('refresh_token', json.data.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/auth/refresh-token",
              "host": [
                "{{base_url}}{{api_prefix}}"
              ],
              "path": [
                "auth",
                "refresh-token"
              ]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/auth/logout",
              "host": [
                "{{base_url}}{{api_prefix}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Children",
      "item": [
        {
          "name": "Create Child Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.id) {",
                  "  pm.collectionVariables.set('child_id', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "multipart/form-data"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "first_name",
                  "value": "Aarav",
                  "type": "text"
                },
                {
                  "key": "last_name",
                  "value": "Sharma",
                  "type": "text"
                },
                {
                  "key": "dob",
                  "value": "2018-05-14",
                  "type": "text"
                },
                {
                  "key": "age",
                  "value": "6",
                  "type": "text"
                },
                {
                  "key": "gender",
                  "value": "male",
                  "type": "text"
                },
                {
                  "key": "photo",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/children",
              "host": [
                "{{base_url}}{{api_prefix}}"
              ],
              "path": [
                "children"
              ]
            }
          }
        },
        {
          "name": "Get Child Profiles",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/children",
              "host": [
                "{{base_url}}{{api_prefix}}"
              ],
              "path": [
                "children"
              ]
            }
          }
        },
        {
          "name": "Update Child Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Aarav\",\n  \"last_name\": \"Sharma\",\n  \"dob\": \"2018-05-14\",\n  \"age\": 7,\n  \"gender\": \"male\",\n  \"avatar_image_url\": \"https://example.com/avatar-updated.png\"\n}"
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/children/{{child_id}}",
              "host": [
                "{{base_url}}{{api_prefix}}"
              ],
              "path": [
                "children",
                "{{child_id}}"
              ]
            }
          }
        },
        {
          "name": "Select Active Child Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/children/select/{{child_id}}",
              "host": [
                "{{base_url}}{{api_prefix}}"
              ],
              "path": [
                "children",
                "select",
                "{{child_id}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        }
      ]
    }
  ]
}
