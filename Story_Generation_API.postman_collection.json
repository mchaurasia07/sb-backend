      ]
    },
    {
      "name": "Story Generation - Event Driven Mode",
      "item": [
        {
          "name": "1. Generate Story (Event-Driven, Skip Images, Mock Mode)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 202) {",
                  "    var response = pm.response.json();",
                  "    pm.environment.set('story_id_event', response.data.id);",
                  "    console.log('Event Story ID saved: ' + response.data.id);",
                  "    console.log('Status: ' + response.data.status);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"child_id\": \"{{child_id}}\",\n  \"mode\": \"EVENT_DRIVEN\",\n  \"age_group\": \"5-7\",\n  \"event_description\": \"Today Emma learned to ride a bike without training wheels for the first time! She felt scared at first but kept trying and finally did it!\",\n  \"skip_image_generation\": true,\n  \"skip_validation\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/stories/generate",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "stories",
                "generate"
              ]
            },
            "description": "Generate story with EVENT-DRIVEN mode (personal event)\n\nConvert real-life events into educational stories"
          },
          "response": []
        },
        {
          "name": "2. Generate Story (Event-Driven, Full with Images)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 202) {",
                  "    var response = pm.response.json();",
                  "    pm.environment.set('story_id_event_full', response.data.id);",
