{
  "info": {
    "name": "Story Generation API",
    "description": "Complete Postman collection for story generation endpoints - event-driven, input-driven, with mocking and polling support",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Setup",
      "item": [
        {
          "name": "1. Login and Get Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"YourPassword123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "2. Get Child ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/children",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "children"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Story Generation - Input Driven Mode",
      "item": [
        {
          "name": "1. Generate Story (Input-Driven, Skip Images, Mock Mode)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 202) {",
                  "    var response = pm.response.json();",
                  "    pm.environment.set('story_id', response.data.id);",
                  "    console.log('Story ID saved: ' + response.data.id);",
                  "    console.log('Status: ' + response.data.status);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"child_id\": \"{{child_id}}\",\n  \"mode\": \"INPUT_DRIVEN\",\n  \"age_group\": \"5-7\",\n  \"category\": \"adventure\",\n  \"learning_goal\": \"courage\",\n  \"context\": \"Emma loves exploring and learning about nature. She's curious and brave.\",\n  \"skip_image_generation\": true,\n  \"skip_validation\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/stories/generate",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "stories",
                "generate"
              ]
            },
            "description": "Generate story with INPUT-DRIVEN mode (category, learning goal, context)\n\nWith skip_image_generation=true for fast testing"
          },
          "response": []
        },
        {
          "name": "2. Generate Story (Input-Driven, Full with Images, Mock Mode)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 202) {",
                  "    var response = pm.response.json();",
                  "    pm.environment.set('story_id_full', response.data.id);",
                  "    console.log('Story ID saved: ' + response.data.id);",
                  "    console.log('Status: ' + response.data.status);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"child_id\": \"{{child_id}}\",\n  \"mode\": \"INPUT_DRIVEN\",\n  \"age_group\": \"5-7\",\n  \"category\": \"learning\",\n  \"learning_goal\": \"friendship\",\n  \"context\": \"A story about making new friends at school\",\n  \"skip_image_generation\": false,\n  \"skip_validation\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/stories/generate",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "stories",
                "generate"
              ]
            },
            "description": "Generate story with INPUT-DRIVEN mode with FULL image generation\n\nWith skip_image_generation=false to generate all images"
          },
          "response": []
        },
        {
          "name": "3. Generate Story (Input-Driven, Different Age Group)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 202) {",
                  "    var response = pm.response.json();",
                  "    pm.environment.set('story_id_toddler', response.data.id);",
                  "    console.log('Toddler Story ID: ' + response.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"child_id\": \"{{child_id}}\",\n  \"mode\": \"INPUT_DRIVEN\",\n  \"age_group\": \"2-4\",\n  \"category\": \"animals\",\n  \"learning_goal\": \"colors\",\n  \"context\": \"Little ones learn about animals and colors\",\n  \"skip_image_generation\": true,\n  \"skip_validation\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/stories/generate",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "stories",
                "generate"
              ]
            },
            "description": "Generate story for TODDLER age group (2-4)\n\nShows age-appropriate vocabulary and page count"
          },
          "response": []
