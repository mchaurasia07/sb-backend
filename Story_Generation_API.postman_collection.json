              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"child_id\": \"{{child_id}}\",\n  \"mode\": \"EVENT_DRIVEN\",\n  \"age_group\": \"8-12\",\n  \"event_description\": \"Yesterday Emma's soccer team lost their championship game. At first she felt disappointed, but she realized she made great friends and learned important skills. The coach praised her effort and teamwork.\",\n  \"skip_image_generation\": false,\n  \"skip_validation\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/stories/generate",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "stories",
                "generate"
              ]
            },
            "description": "Generate story from EVENT with FULL image generation\n\nFor advanced age group (8-12) with longer text"
          },
          "response": []
        },
        {
          "name": "3. Generate Story (Event-Driven, Another Event)",
          "event": [
            {
              "listen": "test",
              "script": [
                "if (pm.response.code === 202) {",
                "    var response = pm.response.json();",
                "    console.log('Story created: ' + response.data.id);",
                "}"
              ]
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"child_id\": \"{{child_id}}\",\n  \"mode\": \"EVENT_DRIVEN\",\n  \"age_group\": \"5-7\",\n  \"event_description\": \"Emma helped her little brother when he was sad. She listened to him, gave him a hug, and they played together. He felt better and smiled.\",\n  \"skip_image_generation\": true,\n  \"skip_validation\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/stories/generate",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "stories",
                "generate"
              ]
            },
            "description": "Another event-based story: Emma helping sibling"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Story Retrieval & Polling",
      "item": [
        {
          "name": "1. Get Story (Check Status)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/stories/{{story_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "stories",
                "{{story_id}}"
              ]
            },
            "description": "Get story details by ID - Use for POLLING\n\nReturns:\n- PENDING: Story still generating\n- IN_PROGRESS: Workflow executing\n- COMPLETED: Story ready with pages and images\n- FAILED: Generation failed"
          },
          "response": []
        },
        {
          "name": "2. Get Story (Wait for Completion - Polling Loop)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var response = pm.response.json();",
                  "var status = response.data.status;",
                  "",
                  "console.log('Story Status: ' + status);",
                  "console.log('Current Step: ' + response.data.current_step);",
                  "",
                  "if (status === 'COMPLETED') {",
                  "    console.log('✓ Story generation complete!');",
                  "    console.log('Title: ' + response.data.title);",
                  "    console.log('Pages: ' + response.data.pages.length);",
                  "} else if (status === 'FAILED') {",
                  "    console.log('✗ Story generation failed!');",
                  "    console.log('Error: ' + response.data.error_message);",
                  "} else {",
                  "    console.log('Story still generating... will retry in 5 seconds');",
                  "    console.log('Current step: ' + response.data.current_step);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/stories/{{story_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "stories",
                "{{story_id}}"
              ]
            },
            "description": "Polling endpoint - Keep calling until COMPLETED\n\nIn production, frontend would poll every 3-5 seconds"
          },
          "response": []
        },
        {
          "name": "3. Get Story Steps (Audit Trail)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/stories/{{story_id}}/steps",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "stories",
                "{{story_id}}",
                "steps"
              ]
            },
            "description": "Get audit trail for story generation workflow\n\nShows all 6 steps:\n- Step name\n- Status (COMPLETED/FAILED)\n- Retry count\n- Error messages\n- Timing data (started_at, completed_at)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Story Listing",
      "item": [
        {
          "name": "1. List All Stories for User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/stories",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "stories"
              ]
            },
            "description": "List all stories for current user\n\nReturns stories in reverse chronological order (newest first)"
          },
          "response": []
        },
        {
          "name": "2. List Stories for Specific Child",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/stories?child_id={{child_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "stories"
              ],
              "query": [
                {
                  "key": "child_id",
                  "value": "{{child_id}}"
                }
              ]
            },
            "description": "List stories for a specific child\n\nFilter by child_id query parameter"
          },
          "response": []
        }
      ]
    },
    {
