{
  "info": {
    "name": "SB Backend Audio API",
    "description": "Focused Postman collection for generic audio catalog, parent child-audio assignment, and child audio library APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "api_prefix",
      "value": "/api/v1"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "child_access_token",
      "value": ""
    },
    {
      "key": "child_id",
      "value": ""
    },
    {
      "key": "generic_audio_id",
      "value": ""
    },
    {
      "key": "child_audio_id",
      "value": ""
    },
    {
      "key": "audio_language",
      "value": "en"
    }
  ],
  "item": [
    {
      "name": "Generic Audio Catalog",
      "item": [
        {
          "name": "Create Generic Audio",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.id) {",
                  "  pm.collectionVariables.set('generic_audio_id', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "Bedtime Music",
                  "type": "text"
                },
                {
                  "key": "language",
                  "value": "{{audio_language}}",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "Soft bedtime audio for kids",
                  "type": "text"
                },
                {
                  "key": "status",
                  "value": "active",
                  "type": "text"
                },
                {
                  "key": "audio",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "image",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/generic-audios",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "{{api_prefix}}",
                "generic-audios"
              ]
            }
          }
        },
        {
          "name": "List Generic Audios",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/generic-audios?page=1&page_size=20&status=active&language={{audio_language}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "{{api_prefix}}",
                "generic-audios"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "page_size",
                  "value": "20"
                },
                {
                  "key": "status",
                  "value": "active"
                },
                {
                  "key": "language",
                  "value": "{{audio_language}}"
                }
              ]
            }
          }
        },
        {
          "name": "Get Generic Audio",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/generic-audios/{{generic_audio_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "{{api_prefix}}",
                "generic-audios",
                "{{generic_audio_id}}"
              ]
            }
          }
        },
        {
          "name": "Update Generic Audio",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bedtime Music Updated\",\n  \"language\": \"{{audio_language}}\",\n  \"audio_url\": \"https://example.com/audio/bedtime-music-updated.mp3\",\n  \"image_url\": \"https://example.com/images/bedtime-music-updated.png\",\n  \"description\": \"Updated soft bedtime audio\",\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/generic-audios/{{generic_audio_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "{{api_prefix}}",
                "generic-audios",
                "{{generic_audio_id}}"
              ]
            }
          }
        },
        {
          "name": "Delete Generic Audio",
          "request": {
            "method": "DELETE",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/generic-audios/{{generic_audio_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "{{api_prefix}}",
                "generic-audios",
                "{{generic_audio_id}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Parent Child Audio Library",
      "item": [
        {
          "name": "List Child Audios",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/children/{{child_id}}/audios?page=1&page_size=20&language={{audio_language}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "{{api_prefix}}",
                "children",
                "{{child_id}}",
                "audios"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "page_size",
                  "value": "20"
                },
                {
                  "key": "language",
                  "value": "{{audio_language}}"
                }
              ]
            }
          }
        },
        {
          "name": "Add Generic Audio To Child",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.child_audio_id) {",
                  "  pm.collectionVariables.set('child_audio_id', json.data.child_audio_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"audio_id\": \"{{generic_audio_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/children/{{child_id}}/audios",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "{{api_prefix}}",
                "children",
                "{{child_id}}",
                "audios"
              ]
            }
          }
        },
        {
          "name": "Remove Audio From Child",
          "request": {
            "method": "DELETE",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/children/{{child_id}}/audios/{{child_audio_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "{{api_prefix}}",
                "children",
                "{{child_id}}",
                "audios",
                "{{child_audio_id}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Child Dashboard Audio Library",
      "description": "Use child_access_token from child login for these requests.",
      "item": [
        {
          "name": "List My Audios",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{child_access_token}}",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/child-library/audios?page=1&page_size=20&language={{audio_language}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "{{api_prefix}}",
                "child-library",
                "audios"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "page_size",
                  "value": "20"
                },
                {
                  "key": "language",
                  "value": "{{audio_language}}"
                }
              ]
            }
          }
        },
        {
          "name": "Get My Audio",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{child_access_token}}",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/child-library/audios/{{child_audio_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "{{api_prefix}}",
                "child-library",
                "audios",
                "{{child_audio_id}}"
              ]
            }
          }
        }
      ]
    }
  ]
}
